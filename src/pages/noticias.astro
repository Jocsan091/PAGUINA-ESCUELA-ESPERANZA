---
import PaginaSitio from "../componentes/sitio/PaginaSitio.astro";
import { formatNewsDate, getNewsImage, listarNoticiasPublicas } from "../lib/noticias";

const noticias = await listarNoticiasPublicas();
---

<PaginaSitio title="Noticias | Escuela Esperanza">
  <main class="internal-page">
    <section class="internal-hero">
      <div class="internal-hero-content">
        <span class="internal-kicker">Noticias</span>
        <h1>Todas las noticias</h1>
      </div>
    </section>

    <section class="news-page-section">
      <div class="news-page-header">
        <p>
          En esta vista se mostraran todas las noticias publicadas por el
          administrador.
        </p>
      </div>

      {
        noticias.length > 0 ? (
          <div class="news-page-list">
            {noticias.map((noticia) => (
              <article class="news-page-card">
                <div class="news-page-media">
                  <img src={getNewsImage(noticia.imagen)} alt="Imagen de noticia" />

                  <div class="news-date-badge news-date-badge--page">
                    <span class="news-date-icon">
                      <i class="fa-solid fa-book-open"></i>
                    </span>
                    <span class="news-date-text">{formatNewsDate(noticia.fecha)}</span>
                  </div>
                </div>

                <div class="news-page-content">
                  <h2 class="news-page-title">{noticia.titulo}</h2>
                  <p>{noticia.contenido}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="news-empty-state news-empty-state--page">
            <p>Todavia no hay noticias cargadas para mostrar al publico.</p>
          </div>
        )
      }
    </section>
  </main>
</PaginaSitio>
