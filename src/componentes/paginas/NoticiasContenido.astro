---
import {
  formatNewsDate,
  getNewsDate,
  getNewsImage,
  getNewsPageUrl,
  getNewsSummary,
  getNewsUrl,
  type Noticia
} from "../../lib/noticias";

interface Props {
  noticias: Noticia[];
  currentPage: number;
  totalPages: number;
}

const { noticias, currentPage, totalPages } = Astro.props;
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Noticias</span>
      <h1>Todas las noticias</h1>
    </div>
  </section>

  <section class="news-page-section">
    {
      noticias.length > 0 ? (
        <>
          <div class="news-page-list">
            {noticias.map((noticia) => (
              <article class="news-page-card">
                <a class="news-page-media" href={getNewsUrl(noticia)} aria-label={`Leer ${noticia.data.title}`}>
                <img src={getNewsImage(noticia.data.image)} alt={noticia.data.title} />

                <div class="news-date-badge news-date-badge--page">
                  <span class="news-date-icon">
                    <i class="fa-solid fa-book-open"></i>
                  </span>
                  <span class="news-date-text">{formatNewsDate(getNewsDate(noticia))}</span>
                </div>
                </a>

                <div class="news-page-content">
                  <h2 class="news-page-title">
                    <a href={getNewsUrl(noticia)}>{noticia.data.title}</a>
                  </h2>
                  <p class="news-page-summary">{getNewsSummary(noticia, 210)}</p>
                  <a class="news-read-more" href={getNewsUrl(noticia)}>Leer noticia</a>
                </div>
              </article>
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="news-pagination" aria-label="Paginacion de noticias">
              {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
                <a
                  href={getNewsPageUrl(page)}
                  class:list={["news-pagination-link", { active: page === currentPage }]}
                  aria-current={page === currentPage ? "page" : undefined}
                >
                  {page}
                </a>
              ))}
            </nav>
          )}
        </>
      ) : (
        <div class="news-empty-state news-empty-state--page">
          <p>No hay noticias publicadas.</p>
        </div>
      )
    }
  </section>
</main>
