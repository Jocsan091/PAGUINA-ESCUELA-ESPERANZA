---
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";

interface Bloque {
  titulo: string;
  texto: string;
  icono: string;
}

interface Props {
  kicker: string;
  titulo: string;
  subtitulo: string;
  imagen?: string;
  descripcion: string[];
  bloques: Bloque[];
  variante?: "normal" | "historia";
}

const { kicker, titulo, subtitulo, imagen, descripcion, bloques, variante = "normal" } = Astro.props;
const descripcionLateral = variante === "historia" ? descripcion.slice(0, 4) : descripcion;
const descripcionInferior = variante === "historia" ? descripcion.slice(4) : [];
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">{kicker}</span>
      <h1>{titulo}</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="info-page-section">
    <div class="info-page-container">
      <article class:list={["info-page-intro", { "info-page-intro--story": variante === "historia" }]}>
        <div class="info-page-copy">
          <span>{kicker}</span>
          <h2>{subtitulo}</h2>

          {variante === "historia" ? (
            <>
              <div class="info-page-story-top">
                <div>
                  {descripcionLateral.map((parrafo) => (
                    <p>{parrafo}</p>
                  ))}
                </div>

                {imagen && <img class="info-page-story-image" src={imagen} alt={titulo} />}
              </div>

              {descripcionInferior.map((parrafo) => (
                <p>{parrafo}</p>
              ))}
            </>
          ) : (
            descripcionLateral.map((parrafo) => (
              <p>{parrafo}</p>
            ))
          )}
        </div>

        {variante !== "historia" && imagen && <img src={imagen} alt={titulo} />}
      </article>

      {bloques.length > 0 && (
        <div class="info-page-grid">
          {bloques.map((bloque) => (
            <article class="info-page-card">
              <span><i class={`fa-solid ${bloque.icono}`}></i></span>
              <h3>{bloque.titulo}</h3>
              <p>{bloque.texto}</p>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</main>
