---
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Escuela Esperanza</span>
      <h1>Contacto</h1>
      <p>Estamos disponibles para orientar consultas de estudiantes, apoderados y comunidad educativa.</p>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="contact-page-section">
    <div class="contact-page-container">
      <article class="contact-page-card">
        <span><i class="fa-solid fa-phone"></i></span>
        <h2>Telefono</h2>
        <a href="tel:+56712244049">(71) 224 4049</a>
      </article>

      <article class="contact-page-card">
        <span><i class="fa-solid fa-envelope"></i></span>
        <h2>Correo</h2>
        <a href="mailto:escuelaesperanza@daemtalca.cl">escuelaesperanza@daemtalca.cl</a>
      </article>

      <article class="contact-page-card">
        <span><i class="fa-regular fa-clock"></i></span>
        <h2>Horario</h2>
        <p>Lunes a jueves: 08:30 - 17:00 hrs</p>
        <p>Viernes: 08:30 - 14:00 hrs</p>
      </article>
    </div>
  </section>
</main>
