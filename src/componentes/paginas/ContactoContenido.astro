---
import AccionesPaginaInterna from "./AccionesPaginaInterna.astro";
import { contactoEscuela } from "../../data/siteData";
---

<main class="internal-page">
  <section class="internal-hero">
    <div class="internal-hero-content">
      <span class="internal-kicker">Escuela Esperanza</span>
      <h1>Contacto</h1>
      <AccionesPaginaInterna sectionHref="/" sectionLabel="Inicio" sectionIcon="fa-house" />
    </div>
  </section>

  <section class="contact-page-section">
    <div class="contact-page-container">
      <article class="contact-page-card">
        <span><i class="fa-solid fa-phone"></i></span>
        <h2>Telefono</h2>
        <a href={contactoEscuela.telefonoHref}>{contactoEscuela.telefono}</a>
      </article>

      <article class="contact-page-card">
        <span><i class="fa-solid fa-envelope"></i></span>
        <h2>Correo</h2>
        <a href={contactoEscuela.correoHref}>{contactoEscuela.correo}</a>
      </article>

      <article class="contact-page-card">
        <span><i class="fa-regular fa-clock"></i></span>
        <h2>Horario</h2>
        <p>Lunes a jueves: 08:30 - 17:00 hrs</p>
        <p>Viernes: 08:30 - 14:00 hrs</p>
      </article>

      <section class="contact-map-panel">
        <div class="contact-map-copy">
          <span><i class="fa-solid fa-location-dot"></i></span>
          <h2>Direccion</h2>
          <p>{contactoEscuela.direccion}</p>
        </div>

        <iframe
          src={contactoEscuela.mapaSrc}
          title="Mapa de ubicacion de Escuela Esperanza"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </section>
    </div>
  </section>
</main>
